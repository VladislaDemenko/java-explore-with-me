{
  "info": {
    "name": "Comments Feature Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Setup: Create test data",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Создаём пользователя",
              "pm.sendRequest({",
              "    url: pm.variables.get('baseUrl') + '/admin/users',",
              "    method: 'POST',",
              "    header: { 'Content-Type': 'application/json' },",
              "    body: JSON.stringify({ name: 'Test User', email: 'test@test.com' })",
              "}, function (err, res) {",
              "    if (res.code === 201) {",
              "        pm.collectionVariables.set('userId', res.json().id);",
              "    } else {",
              "        // Пользователь уже существует, получаем его",
              "        pm.sendRequest({",
              "            url: pm.variables.get('baseUrl') + '/admin/users?from=0&size=1',",
              "            method: 'GET'",
              "        }, function (err2, res2) {",
              "            pm.collectionVariables.set('userId', res2.json()[0].id);",
              "        });",
              "    }",
              "    ",
              "    // Создаём категорию",
              "    pm.sendRequest({",
              "        url: pm.variables.get('baseUrl') + '/admin/categories',",
              "        method: 'POST',",
              "        header: { 'Content-Type': 'application/json' },",
              "        body: JSON.stringify({ name: 'Test Category ' + Date.now() })",
              "    }, function (err3, res3) {",
              "        if (res3.code === 201) {",
              "            pm.collectionVariables.set('categoryId', res3.json().id);",
              "        }",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/events?from=0&size=1",
          "host": ["{{baseUrl}}"],
          "path": ["events"],
          "query": [
            {"key": "from", "value": "0"},
            {"key": "size", "value": "1"}
          ]
        }
      }
    },
    {
      "name": "Public: Get event comments",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is array', function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/events/1/comments?from=0&size=10",
          "host": ["{{baseUrl}}"],
          "path": ["events", "1", "comments"],
          "query": [
            {"key": "from", "value": "0"},
            {"key": "size", "value": "10"}
          ]
        }
      }
    },
    {
      "name": "Public: Get comment by ID fails with 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/events/1/comments/999",
          "host": ["{{baseUrl}}"],
          "path": ["events", "1", "comments", "999"]
        }
      }
    },
    {
      "name": "Private: Create comment fails with 404 for non-existent user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"text\": \"Great event!\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/999/comments?eventId=1",
          "host": ["{{baseUrl}}"],
          "path": ["users", "999", "comments"],
          "query": [
            {"key": "eventId", "value": "1"}
          ]
        }
      }
    },
    {
      "name": "Private: Update comment fails with 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {"key": "Content-Type", "value": "application/json"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"text\": \"Updated comment\"}"
        },
        "url": {
          "raw": "{{baseUrl}}/users/1/comments/999",
          "host": ["{{baseUrl}}"],
          "path": ["users", "1", "comments", "999"]
        }
      }
    },
    {
      "name": "Private: Delete comment fails with 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users/1/comments/999",
          "host": ["{{baseUrl}}"],
          "path": ["users", "1", "comments", "999"]
        }
      }
    },
    {
      "name": "Admin: Delete comment fails with 404",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/comments/999",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "comments", "999"]
        }
      }
    }
  ]
}